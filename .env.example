# ============================================================
# AUTOMATISMOS — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores necesarios.
# Solo DATABASE_URL es obligatorio. El resto activa funcionalidades.
#
# Uso:
#   cp .env.example .env
#   nano .env        # editar valores
#   docker compose up -d
# ============================================================

# ====== PostgreSQL ======
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=automatismos
DB_PORT=5432

# ====== Puertos de las apps ======
API_PORT=3001
WEB_PORT=3002

# ====== LLM (OpenAI / compatible) ======
LLM_API_KEY=
LLM_PROVIDER=openai
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ====== Generación de imágenes ======
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_API_KEY=

# ====== Cloudinary (upload & optimización) ======
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ====== Meta (Instagram / Facebook) ======
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_FB_PAGE_ID=

# ====== Telegram ======
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ====== HeyGen (Video / Avatar IA) ======
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ====== ElevenLabs (Voice Synthesis) ======
ELEVENLABS_API_KEY=

# ====== Supabase (opcional — dejar vacío para modo dev) ======
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ====== Misc ======
NODE_ENV=production
CRON_SECRET=cambiar-esto-en-produccion
