# ============================================================
# SYNDRA / AUTOMATISMOS — Variables de entorno
# ============================================================
# Copia este archivo como .env y rellena los valores necesarios.
# Solo DATABASE_URL es obligatorio. El resto activa funcionalidades.
#
# Uso local:
#   cp .env.example .env
#   nano .env
#   docker compose up -d
# ============================================================

# ====== PostgreSQL ======
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=automatismos
DB_PORT=5432
# Cadena completa usada por Prisma y NestJS
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/automatismos

# ====== Puertos de las apps ======
API_PORT=3001
WEB_PORT=3002

# ====== URLs de la app ======
# URL pública del frontend (para redirects, emails, etc.)
APP_URL=http://localhost:3002
NEXT_PUBLIC_URL=http://localhost:3002
# URL del API vista desde el frontend (browser)
NEXT_PUBLIC_API_URL=http://localhost:3001
# URL del API vista desde el server-side (SSR / proxy routes)
API_URL=http://localhost:3001
INTERNAL_API_URL=http://localhost:3001

# ====== Autenticación / JWT ======
JWT_SECRET=cambiar-esto-en-produccion
# Solo si usas Supabase Auth:
# SUPABASE_JWT_SECRET=

# ====== Seguridad / Credenciales ======
# Cifrado de tokens OAuth almacenados en BD
CREDENTIALS_SECRET=cambiar-esto-en-produccion

# ====== LLM (OpenAI / compatible) ======
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o

# ====== Generación de imágenes ======
IMAGE_GEN_PROVIDER=mock
IMAGE_GEN_API_KEY=

# ====== Cloudinary (upload & optimización) ======
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ====== Meta (Instagram / Facebook) ======
META_APP_ID=
META_APP_SECRET=
META_ACCESS_TOKEN=
META_IG_USER_ID=
META_FB_PAGE_ID=
# Alias usados por ConfigService (mismos valores que arriba)
# META_INSTAGRAM_ACCOUNT_ID=
# META_FACEBOOK_PAGE_ID=

# ====== Telegram ======
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
TELEGRAM_ADMIN_CHAT_ID=
TELEGRAM_WEBHOOK_URL=

# ====== HeyGen (Video / Avatar IA) ======
HEYGEN_API_KEY=
HEYGEN_AVATAR_ID=
HEYGEN_VOICE_ID=

# ====== ElevenLabs (Voice Synthesis) ======
ELEVENLABS_API_KEY=

# ====== Proveedores de video IA (sistema de créditos) ======
REPLICATE_API_TOKEN=
FAL_KEY=
DID_API_KEY=
HEDRA_API_KEY=
# Proveedores extra (opcionales)
PIKA_API_KEY=
LUMA_API_KEY=
GPU_WORKER_URL=

# ====== PayPal (Pagos) ======
PAYPAL_CLIENT_ID=
PAYPAL_CLIENT_SECRET=
PAYPAL_WEBHOOK_ID=

# IDs de planes de suscripción de PayPal (precio completo)
PAYPAL_PLAN_STARTER_MONTHLY=
PAYPAL_PLAN_STARTER_YEARLY=
PAYPAL_PLAN_CREATOR_MONTHLY=
PAYPAL_PLAN_CREATOR_YEARLY=
PAYPAL_PLAN_PRO_MONTHLY=
PAYPAL_PLAN_PRO_YEARLY=

# IDs de planes con descuento 20% para referidos (1er ciclo con trial rebajado)
PAYPAL_PLAN_STARTER_MONTHLY_DISCOUNT=
PAYPAL_PLAN_STARTER_YEARLY_DISCOUNT=
PAYPAL_PLAN_CREATOR_MONTHLY_DISCOUNT=
PAYPAL_PLAN_CREATOR_YEARLY_DISCOUNT=
PAYPAL_PLAN_PRO_MONTHLY_DISCOUNT=
PAYPAL_PLAN_PRO_YEARLY_DISCOUNT=

# ====== Email (Resend) ======
RESEND_API_KEY=
EMAIL_FROM=noreply@syndra.dev

# ====== Discord (notificaciones) ======
DISCORD_WEBHOOK_URL=

# ====== Supabase (opcional — dejar vacío para modo dev) ======
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ====== Almacenamiento local ======
# Directorio para archivos subidos (media, exports…)
UPLOAD_DIR=./uploads

# ====== Misc ======
NODE_ENV=development
CRON_SECRET=cambiar-esto-en-produccion
