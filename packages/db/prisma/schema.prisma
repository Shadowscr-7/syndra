// ============================================================
// Prisma Schema — Automatismos Platform
// ============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================================
// USER — Entidad principal de autenticación
// ============================================================

model User {
  id             String   @id @default(cuid())
  email          String   @unique
  passwordHash   String   @map("password_hash")
  name           String?
  avatarUrl      String?  @map("avatar_url")
  role           UserRole @default(USER)
  isBlocked      Boolean  @default(false) @map("is_blocked")
  emailVerified  Boolean  @default(false) @map("email_verified")
  referredByCode String?  @map("referred_by_code") // affiliate code used at registration
  referralCode   String?  @unique @map("referral_code")  // this user's own shareable code
  lastLoginAt    DateTime? @map("last_login_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  workspaces    WorkspaceUser[]
  refreshTokens RefreshToken[]

  // Affiliate relations
  collaboratorReferrals AffiliateReferral[] @relation("CollaboratorReferrals")
  userReferrals         AffiliateReferral[] @relation("UserReferrals")
  collaboratorPayouts   CommissionPayout[]  @relation("CollaboratorPayouts")
  auditLogs             AuditLog[]
  userCredentials       UserCredential[]
  telegramLink          TelegramLink?
  telegramLinkTokens    TelegramLinkToken[]
  personas              UserPersona[]
  contentProfiles       ContentProfile[]
  visualStyleProfiles   VisualStyleProfile[]
  mediaFiles            UserMedia[]
  mediaFolders          MediaFolder[]
  publishSchedules      PublishSchedule[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens     PasswordResetToken[]
  editorialComments       EditorialComment[]
  editorialAssignments    EditorialAssignment[]
  approvalSteps           ApprovalStep[]

  @@map("users")
}

enum UserRole {
  ADMIN
  COLLABORATOR
  USER
}

// ============================================================
// REFRESH TOKENS — JWT refresh token tracking
// ============================================================

model RefreshToken {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  token     String   @unique
  family    String   @default(cuid()) // token family for rotation detection
  expiresAt DateTime @map("expires_at")
  revokedAt DateTime? @map("revoked_at")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
  @@map("refresh_tokens")
}

// ============================================================
// WORKSPACE & BRAND
// ============================================================

model Workspace {
  id           String   @id @default(cuid())
  name         String
  slug         String   @unique @default(cuid())
  timezone     String   @default("America/Mexico_City")
  logoUrl      String?  @map("logo_url")
  primaryColor String?  @map("primary_color")
  objectives   String[] @default([])
  activeChannels String[] @default(["instagram", "facebook"]) @map("active_channels")
  onboardingCompleted Boolean @default(false) @map("onboarding_completed")
  industry     String?  // tech, coaching, ecommerce, personal_brand, etc.
  operationMode OperationMode @default(APPROVAL_REQUIRED) @map("operation_mode")
  useOwnCredentials Boolean @default(false) @map("use_own_credentials") // true = user's own API keys (no credits), false = platform keys (credits)
  learningConfig Json?  @map("learning_config") // {autoApply: bool, dimensions: string[], minConfidence: float}
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  // Relations
  brandProfile    BrandProfile?
  contentThemes   ContentTheme[]
  campaigns       Campaign[]
  businessProfile BusinessProfile?
  businessBriefs  BusinessBrief[]
  apiCredentials  ApiCredential[]
  editorialRuns   EditorialRun[]
  researchSources ResearchSource[]
  users           WorkspaceUser[]
  subscription    Subscription?
  invitations     Invitation[]
  usageRecords    UsageRecord[]
  alerts          WorkspaceAlert[]
  churnRisk       ChurnRiskSignal?
  learningProfiles ContentLearningProfile[]
  learningDecisions LearningDecisionLog[]
  strategyPlans   StrategyPlan[]
  trendSignals    TrendSignal[]
  experiments     ContentExperiment[]
  brandMemory     BrandMemory?
  fatigueScores   ContentFatigueScore[]
  sourceTrust     SourceTrustProfile[]
  complianceRules ComplianceRule[]
  onboardingProgress OnboardingProgress?
  contentPlaybooks ContentPlaybook[]
  videoRenderJobs  VideoRenderJob[]
  videoCredits     VideoCredit[]
  aiCredits        AICredit[]
  creditBalance    CreditBalance?
  avatarProfiles   AvatarProfile[]
  weeklyPlanConfigs WeeklyPlanConfig[]
  weeklyPlanBatches WeeklyPlanBatch[]

  @@map("workspaces")
}

model WorkspaceUser {
  id          String   @id @default(cuid())
  userId      String   @map("user_id")
  workspaceId String   @map("workspace_id")
  role        WorkspaceRole @default(OWNER)
  isDefault   Boolean  @default(false) @map("is_default") // workspace por defecto del usuario
  createdAt   DateTime @default(now()) @map("created_at")

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@map("workspace_users")
}

enum WorkspaceRole {
  OWNER
  EDITOR
  VIEWER
}

model BrandProfile {
  id              String   @id @default(cuid())
  workspaceId     String   @unique @map("workspace_id")
  voice           String   @default("") // Descripción de la voz de marca
  tone            String   @default("didáctico") // Tono por defecto
  allowedClaims   String[] @default([]) @map("allowed_claims")
  baseCta         String   @default("") @map("base_cta")
  prohibitedTopics String[] @default([]) @map("prohibited_topics")
  topicWhitelist  String[] @default([]) @map("topic_whitelist") // Temas permitidos (vacío = todos)
  topicBlacklist  String[] @default([]) @map("topic_blacklist") // Temas bloqueados
  hashtags        String[] @default([])
  visualStyle     Json?    @map("visual_style") // Tipografías, colores, etc.
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("brand_profiles")
}

// ============================================================
// BUSINESS PROFILE — Contexto del negocio del usuario
// ============================================================

model BusinessProfile {
  id               String   @id @default(cuid())
  workspaceId      String   @unique @map("workspace_id")
  businessName     String   @default("") @map("business_name")      // "Zapatería El Paso"
  businessType     String   @default("") @map("business_type")      // "ecommerce", "restaurant", "services"
  description      String   @default("") @db.Text                    // Descripción completa del negocio
  slogan           String?                                           // "Los mejores zapatos al mejor precio"
  usp              String?  @db.Text                                 // Unique selling proposition
  targetMarket     String   @default("") @map("target_market")      // "Jóvenes 18-35 que buscan moda accesible"
  products         String[] @default([])                             // Lista de productos/servicios principales
  priceRange       String?  @map("price_range")                     // "$15 - $200"
  websiteUrl       String?  @map("website_url")
  physicalAddress  String?  @map("physical_address")
  phoneNumber      String?  @map("phone_number")
  socialLinks      Json?    @map("social_links")                    // {instagram: "...", facebook: "...", tiktok: "..."}
  brandColors      String[] @default([]) @map("brand_colors")       // ["#FF5733", "#333333"]
  logoMediaId      String?  @map("logo_media_id")                   // ID of UserMedia marked as logo
  promotionStyle   String   @default("balanced") @map("promotion_style") // "aggressive", "balanced", "subtle"
  contentGoals     String[] @default([]) @map("content_goals")      // ["ventas", "branding", "engagement"]
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("business_profiles")
}

// ============================================================
// BUSINESS BRIEF — Productos, ofertas y anuncios del negocio
// ============================================================

model BusinessBrief {
  id              String    @id @default(cuid())
  workspaceId     String    @map("workspace_id")
  type            BriefType
  title           String                          // "Oferta del mes: 30% en zapatillas"
  content         String    @db.Text              // Descripción detallada
  productName     String?   @map("product_name")
  productPrice    String?   @map("product_price")
  productUrl      String?   @map("product_url")
  discountText    String?   @map("discount_text") // "30% OFF", "2x1"
  validFrom       DateTime? @map("valid_from")
  validUntil      DateTime? @map("valid_until")
  mediaIds        String[]  @default([]) @map("media_ids")   // UserMedia IDs
  isActive        Boolean   @default(true) @map("is_active")
  priority        Int       @default(5)           // 1-10
  usageCount      Int       @default(0) @map("usage_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, isActive])
  @@map("business_briefs")
}

enum BriefType {
  PRODUCT
  SERVICE
  OFFER
  ANNOUNCEMENT
  TESTIMONIAL
  FAQ
  SEASONAL
  BRAND_STORY
}

// ============================================================
// CONTENT THEMES & CAMPAIGNS
// ============================================================

model ContentTheme {
  id              String   @id @default(cuid())
  workspaceId     String   @map("workspace_id")
  name            String
  keywords        String[] @default([])
  audience        String   @default("")
  priority        Int      @default(5) // 1-10
  preferredFormats String[] @default(["post", "carousel"]) @map("preferred_formats")
  type            ThemeType @default(EVERGREEN)
  isActive        Boolean  @default(true) @map("is_active")
  createdAt       DateTime @default(now()) @map("created_at")
  updatedAt       DateTime @updatedAt @map("updated_at")

  // Product/offer fields for business-driven themes
  productName     String?  @map("product_name")
  productDescription String? @map("product_description")
  productPrice    String?  @map("product_price")
  productUrl      String?  @map("product_url")
  productMediaIds String[] @default([]) @map("product_media_ids")
  promotionStart  DateTime? @map("promotion_start")
  promotionEnd    DateTime? @map("promotion_end")
  discountText    String?  @map("discount_text")

  workspace     Workspace      @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentBriefs ContentBrief[]
  campaignThemes CampaignTheme[]

  @@map("content_themes")
}

enum ThemeType {
  TRENDING
  EVERGREEN
  PRODUCT
  SERVICE
  OFFER
  SEASONAL
  TESTIMONIAL
  BEHIND_SCENES
  EDUCATIONAL
  ANNOUNCEMENT
}

model Campaign {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  name             String
  objective        CampaignObjective
  offer            String?
  landingUrl       String?  @map("landing_url")
  startDate        DateTime @map("start_date")
  endDate          DateTime? @map("end_date")
  kpiTarget        String?  @map("kpi_target")
  contentProfileId String?  @map("content_profile_id")
  userPersonaId    String?  @map("user_persona_id")
  targetChannels   String[] @default(["instagram"]) @map("target_channels")
  channelFormats   Json?    @map("channel_formats")
  operationMode    OperationMode? @map("operation_mode") // Override del workspace, null = hereda

  // Música de fondo para publicaciones que la requieran
  musicEnabled     Boolean  @default(false) @map("music_enabled")
  musicStyle       String?  @map("music_style") // upbeat | calm | corporate | energetic | cinematic | custom
  musicPrompt      String?  @map("music_prompt") // Descripción personalizada

  isActive         Boolean  @default(true) @map("is_active")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace      Workspace       @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  contentProfile ContentProfile? @relation(fields: [contentProfileId], references: [id], onDelete: SetNull)
  userPersona    UserPersona?    @relation(fields: [userPersonaId], references: [id], onDelete: SetNull)
  editorialRuns      EditorialRun[]
  campaignThemes     CampaignTheme[]
  weeklyPlanConfigs  WeeklyPlanConfig[]

  @@map("campaigns")
}

model CampaignTheme {
  id         String @id @default(cuid())
  campaignId String @map("campaign_id")
  themeId    String @map("theme_id")

  campaign Campaign     @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  theme    ContentTheme @relation(fields: [themeId], references: [id], onDelete: Cascade)

  @@unique([campaignId, themeId])
  @@map("campaign_themes")
}

enum CampaignObjective {
  AUTHORITY
  TRAFFIC
  LEAD_CAPTURE
  SALE
  COMMUNITY
  ENGAGEMENT
  PROMOTION
  PRODUCT_LAUNCH
  SEASONAL_SALE
  BRAND_AWARENESS
  CATALOG
}

// ============================================================
// RESEARCH
// ============================================================

model ResearchSource {
  id          String   @id @default(cuid())
  workspaceId String   @map("workspace_id")
  name        String
  type        SourceType
  url         String
  isActive    Boolean  @default(true) @map("is_active")
  lastFetched DateTime? @map("last_fetched")
  createdAt   DateTime @default(now()) @map("created_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("research_sources")
}

enum SourceType {
  RSS
  BLOG
  NEWSLETTER
  SOCIAL
  CHANGELOG
  CUSTOM
  PRODUCT_CATALOG
  BUSINESS_BRIEF
  OFFER_CALENDAR
  FAQ
  TESTIMONIALS_SOURCE
}

model ResearchSnapshot {
  id            String   @id @default(cuid())
  editorialRunId String  @map("editorial_run_id")
  title         String
  source        String
  sourceUrl     String   @map("source_url")
  publishedAt   DateTime? @map("published_at")
  keyPoints     String[] @default([]) @map("key_points")
  suggestedAngle String? @map("suggested_angle")
  relevanceScore Float   @default(0) @map("relevance_score")
  rawDataUrl    String?  @map("raw_data_url") // URL en Storage del snapshot
  createdAt     DateTime @default(now()) @map("created_at")

  editorialRun EditorialRun @relation(fields: [editorialRunId], references: [id], onDelete: Cascade)

  @@map("research_snapshots")
}

// ============================================================
// EDITORIAL PIPELINE
// ============================================================

model EditorialRun {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  campaignId   String?  @map("campaign_id")
  date         DateTime @default(now())
  status       EditorialRunStatus @default(PENDING)
  origin       String   @default("scheduler") // scheduler | manual | campaign
  priority     Int      @default(5)
  errorMessage String?  @map("error_message")
  researchSummary String? @map("research_summary")
  publishWindow DateTime? @map("publish_window")
  targetChannels String[] @default(["instagram"]) @map("target_channels")
  contentProfileId String? @map("content_profile_id")
  userPersonaId    String? @map("user_persona_id")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign          Campaign?          @relation(fields: [campaignId], references: [id])
  contentProfile    ContentProfile?    @relation(fields: [contentProfileId], references: [id])
  userPersona       UserPersona?       @relation(fields: [userPersonaId], references: [id])
  researchSnapshots ResearchSnapshot[]
  contentBrief      ContentBrief?
  approvalEvents    ApprovalEvent[]
  publications      Publication[]
  jobQueueLogs      JobQueueLog[]
  learningDecisions LearningDecisionLog[]
  claimTraces       ClaimTrace[]
  editorialComments EditorialComment[]
  editorialAssignments EditorialAssignment[]
  approvalSteps     ApprovalStep[]
  videoRenderJobs   VideoRenderJob[]
  plannedPublication PlannedPublication?

  @@map("editorial_runs")
}

enum EditorialRunStatus {
  PENDING
  RESEARCH
  STRATEGY
  CONTENT
  MEDIA
  COMPLIANCE
  REVIEW
  APPROVED
  PUBLISHING
  PUBLISHED
  REJECTED
  FAILED
  POSTPONED
}

model ContentBrief {
  id            String   @id @default(cuid())
  editorialRunId String  @unique @map("editorial_run_id")
  themeId       String?  @map("theme_id")
  angle         String   @default("")
  format        ContentFormat @default(POST)
  cta           String   @default("")
  references    String[] @default([])
  seedPrompt    String   @default("") @map("seed_prompt")
  objective     String   @default("")
  tone          String   @default("didáctico")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  editorialRun    EditorialRun     @relation(fields: [editorialRunId], references: [id], onDelete: Cascade)
  theme           ContentTheme?    @relation(fields: [themeId], references: [id])
  contentVersions ContentVersion[]

  @@map("content_briefs")
}

enum ContentFormat {
  POST
  CAROUSEL
  REEL
  STORY
  AVATAR_VIDEO
  HYBRID_MOTION
}

model ContentVersion {
  id            String   @id @default(cuid())
  briefId       String   @map("brief_id")
  version       Int      @default(1)
  isMain        Boolean  @default(false) @map("is_main") // Propuesta principal vs variante
  hook          String   @default("")
  copy          String   @default("")
  caption       String   @default("")
  title         String   @default("")
  hashtags      String[] @default([])
  score         Float?   // Score de calidad estimado
  humanFeedback String?  @map("human_feedback")
  llmPromptUsed String?  @map("llm_prompt_used")
  isApproved    Boolean  @default(false) @map("is_approved")
  createdAt     DateTime @default(now()) @map("created_at")

  brief       ContentBrief @relation(fields: [briefId], references: [id], onDelete: Cascade)
  mediaAssets MediaAsset[]

  @@map("content_versions")
}

// ============================================================
// MEDIA ASSETS
// ============================================================

model MediaAsset {
  id               String   @id @default(cuid())
  contentVersionId String   @map("content_version_id")
  type             MediaType
  prompt           String?  // Prompt usado para generación IA
  provider         String?  // "dall-e", "midjourney", "cloudinary", "heygen", "template"
  originalUrl      String?  @map("original_url")
  optimizedUrl     String?  @map("optimized_url")
  thumbnailUrl     String?  @map("thumbnail_url")
  storagePath      String?  @map("storage_path")
  status           MediaStatus @default(PENDING)
  metadata         Json?    // Dimensiones, duración, formato, etc.
  createdAt        DateTime @default(now()) @map("created_at")

  contentVersion ContentVersion @relation(fields: [contentVersionId], references: [id], onDelete: Cascade)

  @@map("media_assets")
}

enum MediaType {
  IMAGE
  CAROUSEL_SLIDE
  VIDEO
  AVATAR_VIDEO
  THUMBNAIL
  MOTION_GRAPHIC
  AUDIO          // Música de fondo generada por IA
}

enum MediaStatus {
  PENDING
  GENERATING
  PROCESSING
  READY
  FAILED
}

// ============================================================
// APPROVAL (TELEGRAM)
// ============================================================

model ApprovalEvent {
  id             String   @id @default(cuid())
  editorialRunId String   @map("editorial_run_id")
  action         ApprovalAction
  comment        String?
  telegramChatId String?  @map("telegram_chat_id")
  telegramMsgId  String?  @map("telegram_msg_id")
  approvedBy     String?  @map("approved_by")
  versionNumber  Int?     @map("version_number")
  createdAt      DateTime @default(now()) @map("created_at")

  editorialRun EditorialRun @relation(fields: [editorialRunId], references: [id], onDelete: Cascade)

  @@map("approval_events")
}

enum ApprovalAction {
  APPROVED
  CORRECT_TEXT
  CHANGE_TONE
  REGENERATE_IMAGE
  CONVERT_TO_VIDEO
  POSTPONE
  REJECTED
}

// ============================================================
// PUBLICATION
// ============================================================

model Publication {
  id             String   @id @default(cuid())
  editorialRunId String   @map("editorial_run_id")
  platform       Platform
  externalPostId String?  @map("external_post_id")
  permalink      String?
  status         PublicationStatus @default(QUEUED)
  payloadSent    Json?    @map("payload_sent")
  apiResponse    Json?    @map("api_response")
  errorMessage   String?  @map("error_message")
  retryCount     Int      @default(0) @map("retry_count")
  publishedAt    DateTime? @map("published_at")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  // Metrics (updated by analytics)
  likes       Int @default(0)
  comments    Int @default(0)
  shares      Int @default(0)
  saves       Int @default(0)
  reach       Int @default(0)
  impressions Int @default(0)
  engagementRate Float? @map("engagement_rate")
  metricsUpdatedAt DateTime? @map("metrics_updated_at")

  editorialRun EditorialRun @relation(fields: [editorialRunId], references: [id], onDelete: Cascade)
  metricSnapshots MetricSnapshot[]

  @@map("publications")
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  THREADS
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
  META_ADS
  GOOGLE_ADS
  WHATSAPP
  MERCADOLIBRE
  DISCORD
  TELEGRAM
}

enum PublicationStatus {
  QUEUED
  PUBLISHING
  PUBLISHED
  FAILED
  RETRYING
  NEEDS_MANUAL_ATTENTION
}

// ============================================================
// ANALYTICS & METRICS
// ============================================================

/// Snapshots temporales de métricas (2h, 6h, 24h, 48h, 7d)
model MetricSnapshot {
  id             String   @id @default(cuid())
  publicationId  String   @map("publication_id")
  bucket         MetricBucket
  likes          Int      @default(0)
  comments       Int      @default(0)
  shares         Int      @default(0)
  saves          Int      @default(0)
  reach          Int      @default(0)
  impressions    Int      @default(0)
  engagementRate Float?   @map("engagement_rate")
  collectedAt    DateTime @default(now()) @map("collected_at")

  publication Publication @relation(fields: [publicationId], references: [id], onDelete: Cascade)

  @@unique([publicationId, bucket])
  @@map("metric_snapshots")
}

enum MetricBucket {
  H2
  H6
  H24
  H48
  D7
}

/// Insights generados por el motor de optimización
model PerformanceInsight {
  id          String      @id @default(cuid())
  workspaceId String      @map("workspace_id")
  type        InsightType
  title       String
  description String
  data        Json?       // datos de soporte (ej: top themes, best hours, etc)
  score       Float?      // relevancia/confianza del insight
  isActive    Boolean     @default(true) @map("is_active")
  generatedAt DateTime    @default(now()) @map("generated_at")
  expiresAt   DateTime?   @map("expires_at")

  @@map("performance_insights")
}

enum InsightType {
  BEST_FORMAT
  BEST_THEME
  BEST_TONE
  BEST_HOUR
  BEST_CTA
  TREND_UP
  TREND_DOWN
  WEEKLY_SUMMARY
  SUGGESTION
}

// ============================================================
// JOBS & LOGGING
// ============================================================

model JobQueueLog {
  id             String   @id @default(cuid())
  editorialRunId String?  @map("editorial_run_id")
  jobType        String   @map("job_type")
  queue          String   @default("editorial_jobs")
  status         JobStatus @default(QUEUED)
  attempt        Int      @default(1)
  error          String?
  latencyMs      Int?     @map("latency_ms")
  payload        Json?
  result         Json?
  startedAt      DateTime? @map("started_at")
  completedAt    DateTime? @map("completed_at")
  createdAt      DateTime @default(now()) @map("created_at")

  editorialRun EditorialRun? @relation(fields: [editorialRunId], references: [id])

  @@map("job_queue_logs")
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

// ============================================================
// API CREDENTIALS (encrypted at app level)
// ============================================================

model ApiCredential {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  provider     CredentialProvider
  encryptedKey String   @map("encrypted_key") // Cifrado a nivel de aplicación
  expiresAt    DateTime? @map("expires_at")
  scopes       String[] @default([])
  isActive     Boolean  @default(true) @map("is_active")
  lastUsedAt   DateTime? @map("last_used_at")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, provider])
  @@map("api_credentials")
}

enum CredentialProvider {
  META
  GOOGLE
  TELEGRAM
  DISCORD
  LLM
  IMAGE_GEN
  CLOUDINARY
  HEYGEN
  TWITTER
  LINKEDIN
  TIKTOK
  YOUTUBE
  PINTEREST
  WHATSAPP
  MERCADOLIBRE
}

// ============================================================
// PLANS & SUBSCRIPTIONS (Multi-tenant)
// ============================================================

model Plan {
  id             String   @id @default(cuid())
  name           String   @unique // starter, creator, pro
  displayName    String   @map("display_name")
  description    String   @default("")
  monthlyPrice   Int      @default(0) @map("monthly_price") // cents
  yearlyPrice    Int      @default(0) @map("yearly_price")  // cents

  // ── Numeric limits (-1 = unlimited, 0 = disabled) ──
  maxPublications    Int @default(30)  @map("max_publications")
  maxVideos          Int @default(0)   @map("max_videos")
  maxSources         Int @default(3)   @map("max_sources")
  maxChannels        Int @default(2)   @map("max_channels")
  maxEditors         Int @default(1)   @map("max_editors")
  maxPersonas        Int @default(1)   @map("max_personas")
  maxContentProfiles Int @default(1)   @map("max_content_profiles")
  maxVisualStyles    Int @default(1)   @map("max_visual_styles")
  maxStorageMb       Int @default(500) @map("max_storage_mb")
  maxScheduleSlots   Int @default(5)   @map("max_schedule_slots")
  maxExperiments     Int @default(0)   @map("max_experiments")

  // ── Boolean feature flags ──
  analyticsEnabled       Boolean @default(true)  @map("analytics_enabled")
  aiScoringEnabled       Boolean @default(false) @map("ai_scoring_enabled")
  trendDetectionEnabled  Boolean @default(false) @map("trend_detection_enabled")
  aiStrategistEnabled    Boolean @default(false) @map("ai_strategist_enabled")
  videoEnabled           Boolean @default(false) @map("video_enabled")
  brandMemoryEnabled     Boolean @default(false) @map("brand_memory_enabled")
  teamEnabled            Boolean @default(false) @map("team_enabled")
  priorityQueue          Boolean @default(false) @map("priority_queue")
  apiAccess              Boolean @default(false) @map("api_access")
  prioritySupport        Boolean @default(false) @map("priority_support")
  customBranding         Boolean @default(false) @map("custom_branding")
  weeklyPlannerEnabled   Boolean @default(false) @map("weekly_planner_enabled")

  // ── Tiered feature levels ──
  analyticsLevel    String @default("basic")    @map("analytics_level")    // basic | complete | ai
  learningLoopLevel String @default("none")     @map("learning_loop_level") // none | basic | medium | full
  autopilotLevel    String @default("manual")   @map("autopilot_level")    // manual | approval | assisted | full

  isActive  Boolean  @default(true)  @map("is_active")
  createdAt DateTime @default(now()) @map("created_at")

  subscriptions Subscription[]
  licenseKeys   LicenseKey[]

  @@map("plans")
}

model Subscription {
  id               String   @id @default(cuid())
  workspaceId      String   @unique @map("workspace_id")
  planId           String   @map("plan_id")
  status           SubscriptionStatus @default(ACTIVE)
  billingCycle     BillingCycle @default(MONTHLY) @map("billing_cycle")
  // PayPal integration
  paypalSubscriptionId String? @map("paypal_subscription_id")
  paypalCustomerId     String? @map("paypal_customer_id")
  paypalPlanId         String? @map("paypal_plan_id")       // PayPal billing plan ID
  // Legacy Stripe fields (kept for backward compatibility)
  stripeCustomerId String?  @map("stripe_customer_id")
  stripeSubId      String?  @map("stripe_sub_id")
  discountPercent  Int      @default(0) @map("discount_percent") // e.g. 20 for referral
  currentPeriodStart DateTime @default(now()) @map("current_period_start")
  currentPeriodEnd   DateTime @default(now()) @map("current_period_end")
  cancelAtPeriodEnd  Boolean @default(false) @map("cancel_at_period_end")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  plan      Plan      @relation(fields: [planId], references: [id])

  @@map("subscriptions")
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELED
  PAUSED
}

enum BillingCycle {
  MONTHLY
  YEARLY
}

// ============================================================
// INVITATIONS
// ============================================================

model Invitation {
