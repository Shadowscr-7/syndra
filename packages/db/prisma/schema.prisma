  MVP       // Pika/Luma API
  SELFHOST  // GPU propia + open source
  PREMIUM   // HeyGen + ElevenLabs
}

enum VideoInputType {
  IMAGE_TO_VIDEO
  TEXT_TO_VIDEO
  SCRIPT_WITH_VOICE
  AVATAR_TALKING
  CAROUSEL_ANIMATION
}

enum VideoJobStatus {
  QUEUED
  RENDERING
  COMPOSING
  UPLOADING
  COMPLETED
  FAILED
  CANCELLED
}

// ============================================================
// AI CREDITS — Sistema de créditos para operaciones de IA premium
// ============================================================

enum CreditSource {
  PLAN       // Créditos gratis del plan
  PURCHASE   // Comprado via PayPal
  ADDON      // Complemento del plan
  PROMO      // Código promocional
  REFUND     // Devolución por error de generación
}

enum CreditOperationType {
  IMAGE_STANDARD      // 1 crédito  — Replicate Flux-schnell
  IMAGE_TEXT           // 5 créditos — Ideogram/Recraft
  IMAGE_HD             // 3 créditos — Flux-dev
  IMAGE_PRO_TEXT       // 4 créditos — KIE Ideogram V3 (texto en imágenes)
  ANIMATION_5S         // 10 créditos — Wan i2v 5s
  ANIMATION_10S        // 15 créditos
  VIDEO_REEL_10S       // 20 créditos — Wan t2v
  VIDEO_REEL_15S       // 25 créditos
  AVATAR_BASIC_30S     // 30 créditos — D-ID/Hedra
  AVATAR_PREMIUM_30S   // 50 créditos — HeyGen
  VOICE_PREMIUM        // 2 créditos  — ElevenLabs
  MUSIC_BACKGROUND     // 3 créditos  — KIE Suno (música de fondo)
  VIDEO_KIE_SLIDES     // 0 créditos  — FFmpeg local (gratis)
  VIDEO_KIE_VIDEO      // 15 créditos — KIE Video IA
  VIDEO_KIE_AVATAR     // 25 créditos — KIE Avatar
}

model AICredit {
  id              String               @id @default(cuid())
  workspaceId     String               @map("workspace_id")
  amount          Int                  // positivo = recarga, negativo = consumo
  balance         Int                  // balance después de esta operación
  source          CreditSource
  operation       CreditOperationType? // null para recargas
  description     String?
  referenceId     String?              @map("reference_id")
  paypalOrderId   String?              @map("paypal_order_id")
  createdAt       DateTime             @default(now()) @map("created_at")

  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId, createdAt])
  @@index([workspaceId, source])
  @@map("ai_credits")
}

model CreditBalance {
  id               String   @id @default(cuid())
  workspaceId      String   @unique @map("workspace_id")
  totalPurchased   Int      @default(0) @map("total_purchased")
  totalConsumed    Int      @default(0) @map("total_consumed")
  totalRefunded    Int      @default(0) @map("total_refunded")
  currentBalance   Int      @default(0) @map("current_balance")
  isUnlimited      Boolean  @default(false) @map("is_unlimited")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@map("credit_balances")
}

// ============================================================
// AVATAR PROFILE — Avatares IA persistentes
// ============================================================

model AvatarProfile {
  id           String   @id @default(cuid())
  workspaceId  String   @map("workspace_id")
  name         String
  photoUrl     String   @map("photo_url")
  provider     String   // 'heygen' | 'did' | 'hedra'
  externalId   String?  @map("external_id")
  voiceId      String?  @map("voice_id")
  isDefault    Boolean  @default(false) @map("is_default")
  metadata     Json?
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  workspace    Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([workspaceId])
  @@map("avatar_profiles")
}

// ============================================================
// WEEKLY PLANNER — Planificación semanal de publicaciones (Pro)
// ============================================================

model WeeklyPlanConfig {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  name             String   @default("Planificador semanal")
  isActive         Boolean  @default(true) @map("is_active")

  // Días en que se ejecuta el planificador (genera el contenido)
  plannerRunDays   DayOfWeek[] @default([MONDAY]) @map("planner_run_days")
  plannerRunTime   String   @default("08:00") @map("planner_run_time")  // "HH:MM"

  // Días para los que se genera contenido
  publishDays      DayOfWeek[] @default([MONDAY, TUESDAY, WEDNESDAY, THURSDAY, FRIDAY]) @map("publish_days")
  publishTime      String   @default("10:00") @map("publish_time")     // "HH:MM"

  // Modo de contenido: editorial (research externo) o business (recursos de la empresa)
  contentMode      String   @default("editorial") @map("content_mode") // editorial | business

  // Modo de aprobación: telegram (auto-envía por Telegram) o panel (requiere aprobación en panel web)
  approvalMode     String   @default("telegram") @map("approval_mode") // telegram | panel

  // Canales destino
  targetChannels   String[] @default(["instagram"]) @map("target_channels")
  timezone         String   @default("America/Mexico_City")

  // Campaña asociada (opcional) — si se define, hereda canales, persona, perfil, temas y música de la campaña
  campaignId       String?  @map("campaign_id")

  // Música de fondo para publicaciones (Reels/Stories/Shorts)
  musicEnabled     Boolean  @default(false) @map("music_enabled")
  musicStyle       String?  @map("music_style") // upbeat | calm | corporate | energetic | cinematic | custom
  musicPrompt      String?  @map("music_prompt") // Descripción personalizada para generación de música

  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  campaign         Campaign? @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  batches          WeeklyPlanBatch[]

  @@index([workspaceId])
  @@index([campaignId])
  @@map("weekly_plan_configs")
}

enum WeeklyBatchStatus {
  GENERATING
  PENDING_REVIEW
  PARTIALLY_APPROVED
  FULLY_APPROVED
  PUBLISHED
  CANCELLED
}

model WeeklyPlanBatch {
  id               String   @id @default(cuid())
  workspaceId      String   @map("workspace_id")
  configId         String   @map("config_id")
  weekLabel        String   @map("week_label")            // "2026-W12"
  status           WeeklyBatchStatus @default(GENERATING)
  totalItems       Int      @default(0) @map("total_items")
  approvedItems    Int      @default(0) @map("approved_items")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  workspace        Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  config           WeeklyPlanConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  items            PlannedPublication[]

  @@unique([workspaceId, configId, weekLabel])
  @@index([workspaceId])
  @@map("weekly_plan_batches")
}

enum PlannedPublicationStatus {
  GENERATING
  GENERATING_MUSIC
  PENDING_REVIEW
  APPROVED
  MODIFIED
  REJECTED
  PUBLISHING
  PUBLISHED
  FAILED
}

model PlannedPublication {
  id               String   @id @default(cuid())
  batchId          String   @map("batch_id")
  editorialRunId   String?  @unique @map("editorial_run_id")
  scheduledDate    DateTime @map("scheduled_date")
  scheduledTime    String   @map("scheduled_time")        // "HH:MM"
  dayOfWeek        DayOfWeek @map("day_of_week")
  status           PlannedPublicationStatus @default(GENERATING)
  sortOrder        Int      @default(0) @map("sort_order")
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @updatedAt @map("updated_at")

  batch            WeeklyPlanBatch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  editorialRun     EditorialRun? @relation(fields: [editorialRunId], references: [id], onDelete: SetNull)

  @@index([batchId])
  @@index([editorialRunId])
  @@map("planned_publications")
}
