  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  contentProfile ContentProfile?  @relation(fields: [contentProfileId], references: [id], onDelete: SetNull)
  slots          ScheduleSlot[]

  @@index([userId])
  @@map("publish_schedules")
