  time             String              // "09:00"
  socialAccountIds String[] @default([]) @map("social_account_ids")
  priority         Int      @default(0)
  createdAt        DateTime @default(now()) @map("created_at")

  schedule PublishSchedule @relation(fields: [scheduleId], references: [id], onDelete: Cascade)

  @@index([scheduleId])
  @@map("schedule_slots")
}

