// ============================================================
// CONTENT LEARNING LOOP — Aprendizaje adaptativo por workspace
// ============================================================

model ContentLearningProfile {
  id                    String         @id @default(cuid())
  workspaceId           String         @map("workspace_id")
  platform              String?        // null = ALL platforms
  audienceSegment       String?        @map("audience_segment")
  lastCalculatedAt      DateTime?      @map("last_calculated_at")
  dataWindowDays        Int            @default(30) @map("data_window_days")
  minimumDataThreshold  Int            @default(5) @map("minimum_data_threshold")
  confidenceScore       Float          @default(0) @map("confidence_score") // 0-1
  status                LearningStatus @default(LOW_DATA)
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")

  workspace       Workspace            @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  patternScores   ContentPatternScore[]

  @@unique([workspaceId, platform])
  @@map("content_learning_profiles")
}

enum LearningStatus {
  ACTIVE    // Enough data to give recommendations
  LOW_DATA  // Not enough data yet
  DISABLED  // Manually disabled by user
}

model ContentPatternScore {
  id                  String           @id @default(cuid())
  learningProfileId   String           @map("learning_profile_id")
  dimensionType       PatternDimension @map("dimension_type")
  dimensionValue      String           @map("dimension_value") // e.g. "CAROUSEL", "didáctico", "19"
  sampleSize          Int              @default(0) @map("sample_size")
  avgEngagement       Float            @default(0) @map("avg_engagement")
  avgReach            Float            @default(0) @map("avg_reach")
  avgSaves            Float            @default(0) @map("avg_saves")
  avgComments         Float            @default(0) @map("avg_comments")
  weightedScore       Float            @default(0) @map("weighted_score") // normalized 0-100
  trendDirection      TrendDirection   @default(FLAT) @map("trend_direction")
  confidenceScore     Float            @default(0) @map("confidence_score") // 0-1
  updatedAt           DateTime         @updatedAt @map("updated_at")

  learningProfile     ContentLearningProfile @relation(fields: [learningProfileId], references: [id], onDelete: Cascade)

  @@unique([learningProfileId, dimensionType, dimensionValue])
  @@index([learningProfileId, weightedScore(sort: Desc)])
  @@map("content_pattern_scores")
}

enum PatternDimension {
  THEME
  FORMAT
  TONE
  CTA
  HOUR
  DAY
  VISUAL_STYLE
  HOOK_TYPE
  LENGTH
}

enum TrendDirection {
  UP
  DOWN
  FLAT
}

model LearningDecisionLog {
  id                String    @id @default(cuid())
  workspaceId       String    @map("workspace_id")
  editorialRunId    String?   @map("editorial_run_id")
  decisionType      DecisionType @map("decision_type")
