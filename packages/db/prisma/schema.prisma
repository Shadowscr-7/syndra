  reasonSummary     String    @map("reason_summary")
  sourcePatternIds  Json      @default("[]") @map("source_pattern_ids")
  beforeValue       String?   @map("before_value")
  afterValue        String?   @map("after_value")
  impactPrediction  String?   @map("impact_prediction")
  createdAt         DateTime  @default(now()) @map("created_at")

  workspace     Workspace     @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  editorialRun  EditorialRun? @relation(fields: [editorialRunId], references: [id])

  @@index([workspaceId, createdAt(sort: Desc)])
  @@map("learning_decision_logs")
}

enum DecisionType {
  CHOOSE_TONE
  CHOOSE_FORMAT
  CHOOSE_HOUR
  CHOOSE_THEME
  CHOOSE_CTA
  CHOOSE_HOOK
  AVOID_FATIGUE
  BOOST_ENGAGEMENT
}

