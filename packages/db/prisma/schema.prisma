enum DayOfWeek {
  MONDAY
  TUESDAY
  WEDNESDAY
  THURSDAY
  FRIDAY
  SATURDAY
  SUNDAY
}

model ScheduleSlot {
  id               String   @id @default(cuid())
  scheduleId       String   @map("schedule_id")
