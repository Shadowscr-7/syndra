  workspaceId           String    @unique @map("workspace_id")

  // Step completion timestamps
  accountCreatedAt      DateTime? @map("account_created_at")
  emailVerifiedAt       DateTime? @map("email_verified_at")
  workspaceConfiguredAt DateTime? @map("workspace_configured_at")
  brandConfiguredAt     DateTime? @map("brand_configured_at")
  channelsConnectedAt   DateTime? @map("channels_connected_at")
  themesConfiguredAt    DateTime? @map("themes_configured_at")
